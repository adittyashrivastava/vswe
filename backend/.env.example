# Copy to .env and fill in your values
ENV=local
DYNAMODB_ENDPOINT=http://localhost:8000
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# LLM API Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# GitHub App
GITHUB_APP_ID=
GITHUB_CLIENT_ID=          # For GitHub Apps, this is "Client ID" on the app settings page
GITHUB_CLIENT_SECRET=      # Generate under "Client secrets" on the app settings page
GITHUB_APP_PRIVATE_KEY=    # PEM content as single line with \n separators
GITHUB_WEBHOOK_SECRET=     # Same secret set in the GitHub App webhook config

# JWT (change in production)
JWT_SECRET=vswe-local-dev-secret-change-in-production

# URLs (change for production)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Storage
# Leave empty for local dev (uses ./workspaces inside project)
# Set to /efs in production (AWS EFS mount)
EFS_MOUNT_PATH=

# Budget
BUDGET_LIMIT_USD=5.0

# Ngrok (local dev only — for GitHub webhook testing)
# Start: ngrok http 8080
# GitHub App webhook URL: <NGROK_URL>/webhooks/github
NGROK_URL=
